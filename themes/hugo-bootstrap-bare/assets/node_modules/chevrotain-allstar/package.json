    "lib"
  ],
  "dependencies": {
    "lodash-es": "^4.18.1"
  },
  "peerDependencies": {
    "chevrotain": "^12.0.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "shx": "^0.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/langium/chevrotain-allstar"
  },
  "bugs": "https://github.com/langium/chevrotain-allstar/issues",
  "author": {
    "name": "TypeFox",
    "url": "https://www.typefox.io"
  }
