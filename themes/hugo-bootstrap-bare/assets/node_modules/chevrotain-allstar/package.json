{
  "name": "chevrotain-allstar",
  "version": "0.4.3",
  "description": "LL(*) lookahead strategy for the Chevrotain parser library",
  "keywords": [
    "parser",
    "lookahead",
    "chevrotain",
    "langium"
  ],
  "license": "MIT",
  "type": "module",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
    }
  },
  "scripts": {
    "test": "vitest",
    "build": "tsc",
